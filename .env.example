# Alpaca API (https://app.alpaca.markets)
# Use paper trading keys to start
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true
ALPACA_FEED=iex

# Base URLs
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_PAPER_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_URL=https://api.alpaca.markets

# Signal Engine Config
SIGNAL_THRESHOLD=70
MAX_POSITION_RISK_PCT=5

# Tradier API (https://developer.tradier.com)
# Start with sandbox (free), upgrade to production for live data
TRADIER_API_KEY=your_tradier_api_key
TRADIER_SANDBOX=true

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Finnhub (https://finnhub.io — free tier)
FINNHUB_API_KEY=your_finnhub_api_key
